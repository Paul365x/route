/*
** Route
**
** Spreadsheet: contains a route name, location for route xml, locations for town/location, state, display_name, lat, lon and rtept
** locations for each defined in the constants
** takes this information and first geocodes the locations, then creates gpx rtept xml and finally compiles a complete gpx xml route.
**
** 
*/
const locCol = "A";       // location name column
const stateCol = "B";     // state name column
const nameCol = "C";      // column for individualised names
const pinCol = "D";       // column to select pin type
const addrCol = "E";      // generated address column
const latCol = "F";       // generated latitude column
const lonCol = "G";       // generated longitude column
const ptCol = "H";        // generated rtept column
const typeLoc = "B1";     // location of the route type
const nameLoc = "B2";     // cell for name of route
const routeLoc = "B3";    // generated route column
const colStart = 7;       // row where the location data starts

// route type
const routeSet = ["route", "waypoint", "track"];   // valid: route (RTE), waypoint (WPT), track (TRK)

// pin selection
const pinSet = [
                "Circle, Blue","Circle, Green", "Circle, Red",
                "Diamond, Blue","Diamond, Green", "Diamond, Red",
                "Flag, Blue","Flag, Green", "Flag, Red",
                "Square, Blue","Square, Green", "Square, Red"  ];

// route tags
const startRTE = "<rte>";
const endRTE = "</rte>";
const ptStartRTE = "<rtept";
const ptEndRTE = "</rtept>";

// waypoint tags
const ptStartWPT = "<wpt";
const ptEndWPT = "</wpt>";

// track tags
const startTRK = "<trk>";
const endTRK = "</trk>";
const segStartTRK = "<trkseg>";
const segEndTRK = "</trkseg>";
const ptStartTRK = "<trkpt";
const ptEndTRK = "</trkpt>";

// sets up our custom menu
function onOpen() {
  var ui = SpreadsheetApp.getUi();
  // Or DocumentApp or FormApp.
  ui.createMenu('GPX' )
      .addItem('Compact', 'COMPACT' )
      .addItem('Geocode', 'GEOCODE' )
      .addItem('Points', 'POINTS' )
      .addItem("Route","ROUTE")  
      .addItem("Save","SAVE")   
      .addSeparator()
      .addItem("Clear Pins", "CLEARPINS")
      .addItem("Clear Points","CLEARPTS")
      .addItem("Clear Route","CLEARRTE")
      .addItem("Clear Generated","CLEARGEN")
      .addItem("Clear All","CLEARALL")
      .addToUi();  
  doDropdown();
}

// adds a dropdown to pin column
function onEdit(e) {
  let chgRange = e.range;
   
  let col = String.fromCharCode(64 + chgRange.getColumn());
  if (col != locCol) {
     return;
  }
  let row = chgRange.getRow();
  let value = chgRange.getValue();
  let ss = SpreadsheetApp.getActiveSpreadsheet().getActiveSheet();
  let ssName = ss.getName();
 // SpreadsheetApp.getUi().alert(ssName);
  if (ssName != "Work") {
    return;
  }
  var cell = ss.getRange(pinCol + row + ":" + pinCol + row);  

  if (value === "" || value === null) {  
    cell.clearContent();
    cell.clearDataValidations();
    return;
  } else {
    if (cell.getDataValidation() === null) {
      var rule = SpreadsheetApp.newDataValidation().requireValueInList(["None"].concat(pinSet), true).build();
      cell.setDataValidation(rule);  
      cell.setValue("None");
      return;
    }
  }
}

// adds a dropdown allowing selection of point type
function doDropdown( ) {
  var cell = SpreadshreetApp.getActiveSpreadsheet().getRange(typeLoc + ":" + typeLoc);
  var rule = SpreadsheetApp.newDataValidation().requireValueInList(routeSet, true).build();
  cell.setDataValidation(rule);  
  cell.setValue("route");
}

function CLEARPINS() {
  let ss = SpreadsheetApp.getActiveSpreadsheet();
  let rgPin = ss.getRange(pinCol + colStart + ":" + pinCol);
  let numRows = rgPin.getNumRows();
  let rule = SpreadsheetApp.newDataValidation().requireValueInList(["None"].concat(pinSet), true).build();
  for (let i = 1; i <= numRows; i++) {
    let cell = rgPin.getCell(i, 1);
    cell.clearContent();
    cell.clearDataValidations();
    let row = colStart + i - 1;
    let town = ss.getRange(locCol + row + ":" + locCol + row);
    let value = town.getValue();
  //  SpreadsheetApp.getUi().alert(value + " " + row);
    if ((value != "" && value != null) ) {

      cell.setDataValidation(rule);  
      cell.setValue("None");
    }
    
  }

}

function COMPACT() {
  let ss = SpreadsheetApp.getActiveSpreadsheet();
  let lrow =ss.getLastRow();
  for (var i = lrow; i > colStart; i--) {
    let test = ss.getRange(locCol + i + ":" + locCol + i).getValue();
    if (test === "") {
      ss.deleteRow(i);
    }
  }
}


// clears the generated information
function CLEARGEN() {
  SpreadsheetApp.getActiveSpreadsheet().getRange(addrCol + colStart + ":" + ptCol).clearContent();
  CLEARRTE();
}

// clears the generated points
function CLEARPTS() {
  SpreadsheetApp.getActiveSpreadsheet().getRange(ptCol+ colStart + ":" + ptCol).clearContent();
}

// clears the generated route
function CLEARRTE() {
  SpreadsheetApp.getActiveSpreadsheet().getRange(routeLoc + ":" + routeLoc).clearContent();
}

// clears all except for headings
function CLEARALL() {
  let ss = SpreadsheetApp.getActiveSpreadsheet();
  ss.getRange(locCol + colStart + ":" + ptCol).clearContent();
  ss.getRange(nameLoc + ":" + nameLoc).clearContent();
  CLEARRTE();
}


function xmlHeader() {
  let xml = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>\r\n";
  xml = xml + "<gpx version=\"1.1\" creator=\"Paul's Route\"\r\n";
  xml = xml + "xmlns=\"http://www.topografix.com/GPX/1/1\"\r\n";
  xml = xml + "xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\"\r\n";
  xml = xml + "xsi:schemaLocation=\"http://www.topografix.com/GPX/1/1 ";
  xml = xml + "http://www.topografix.com/GPX/1/1/gpx.xsd ";
  xml = xml + "http://www.topografix.com/GPX/gpx_style/0/2 "
  xml = xml + "http://www.topografix.com/GPX/gpx_style/0/2/gpx_style.xsd\"\r\n";
  xml = xml + "xmlns:gpx_style=\"http://www.topografix.com/GPX/gpx_style/0/2\">\r\n";
  return xml;
}

function setTags() {
  var tags = {};
  let ss = SpreadsheetApp.getActiveSpreadsheet();
  let routeType = ss.getRange(typeLoc + ":" + typeLoc).getValue().toString();
  
  switch (routeType) {
    case "track":
      tags["start"] = startTRK;
      tags["end"] = endTRK;
      tags["segstart"] = segStartTRK;
      tags["segend"] = segEndTRK;
      tags["ptstart"] = ptStartTRK;
      tags["ptend"] = ptEndTRK;
      break;
    case "waypoint": 
      tags["ptstart"] = ptStartWPT;
      tags["ptend"] = ptEndWPT;
      break;
    case "route":
    // drop through to default
    default: 
      tags["start"] = startRTE;
      tags["end"] = endRTE;
      tags["ptstart"] = ptStartRTE;
      tags["ptend"] = ptEndRTE;
      break;
  }
  return tags;
}

function SAVE() {
  let ss = SpreadsheetApp.getActiveSpreadsheet();
  let route = ss.getRange(routeLoc + ":" + routeLoc).getValue().toString();

  // setup our file name
  let name = ss.getRange(nameLoc + ":" + nameLoc).getValue().toString();
  name = name.replaceAll(' ','_');
  name = name + ".gpx";

  // get current folder and write the file
  let fileId = ss.getId();
  let file = DriveApp.getFileById(fileId);
  let parents = file.getParents();
  if (parents.hasNext()) {
    let folder = parents.next();
    folder.createFile(name, route, "application/gpx+xml");    
  } else {
    // we are running in root so put it there
    DriveApp.createFile(name, route, "application/gpx+xml");
  }
}

// generates a gpx route file from rtept and name data
function ROUTE() {
  let ss = SpreadsheetApp.getActiveSpreadsheet();
  let src = ss.getRange(ptCol + colStart + ":" + ptCol).getValues();
  let route = ss.getRange(routeLoc + ":" + routeLoc)
  let name = ss.getRange(nameLoc + ":" + nameLoc).getValue();
  let xml = xmlHeader();
  let tags = setTags();

  if ("start" in tags) {
      xml = xml + "\t" + tags["start"];
      if ("segstart" in tags) {
        xml = xml + tags["segstart"];
      } 
      xml = xml + "\r\n";
  }

  if (name != "") {
      xml = xml + "\t\t<name>" + name + "</name>\r\n";
  }

  src.forEach(function(row, index) {
    if (row[0] != "" ) {
        xml = xml + "\t\t" + row[0] + "\r\n";
    }
  });

  if ("end" in tags) {
    if ("segend" in tags) {
      xml = xml + tags["segend"];
    } 
    xml = xml + "\t" + tags["end"] + "\r\n";
  }
  xml = xml + "</gpx>\r\n";
  route.setValue(xml);
}

// generates rtept xml for this location
function POINTS() {
  let ss = SpreadsheetApp.getActiveSpreadsheet();
  let lastRow = ss.getActiveSheet().getLastRow();
  let r = ss.getRange(locCol + colStart + ":" + stateCol + lastRow)
  let targets = ss.getRange(locCol + colStart + ":" + locCol + lastRow).getValues();
  let tags = setTags();

  targets.forEach(function(row, index) {
    let town = row[0].toString();
    let level = index + colStart;

    let name = ss.getRange(nameCol + level + ":" + nameCol + level ).getValue();
    if (name === "") {
        name = ss.getRange(addrCol + level + ":" + addrCol + level ).getValue();
    }
    if (name === "" ) {
      name = ss.getRange(locCol + level + ":" + locCol + level ).getValue();
    }
 
    let pinVal = "";
    let pinType = ss.getRange(pinCol + level + ":" + pinCol + level ).getValue();
    if (pinType != "None") {
        pinVal = "<sym>" + pinType + "</sym>";
    }

    let lat = ss.getRange(latCol + level + ":" + latCol + level ).getValue();
    let lon = ss.getRange(lonCol + level + ":" + lonCol + level ).getValue();
    if ( lat != "" && lon != "" ) {
        let target = ss.getRange(ptCol + level + ":" + ptCol + level)
        target.setValue(tags["ptstart"] + " lat=\"" + lat + "\" lon=\"" + lon +"\"> <name>" + name +"</name>" + pinVal + tags["ptend"]);
    }
  });

}

// geocodes all locations it can find
function GEOCODE() {
  let ss = SpreadsheetApp.getActiveSpreadsheet();
  let r = ss.getRange(locCol + colStart + ":" + stateCol)
  let targets = ss.getRange(locCol + colStart + ":" + locCol).getValues();
  
  targets.forEach(function(row, index) {
    let town = row[0].toString();
    if (town === "") {
      return;
    }
    let level = index + colStart;
    let state = ss.getRange(stateCol + level + ":" + stateCol + level ).getValue();
    var loc = callGeo(town, state);
    if ( Object.keys(loc).length > 0 ) {
        ss.getRange(addrCol + level + ":" + addrCol + level).setValue(loc["display_name"]);
        ss.getRange(latCol + level + ":" + latCol + level).setValue(loc["lat"]);
        ss.getRange(lonCol + level + ":" + lonCol + level).setValue(loc["lon"]);
    }
  });
  
  
}

// geocodes a single location. If it fails leave it blank
function callGeo(town, state) {  
   var url = "https://geocode.maps.co/search?q="+town+"+"+state+"+AU&api_key=<yourkeyhere>"
   var loc = {};
  try {
    var response = UrlFetchApp.fetch(url);
    var jsonText = response.getContentText();
    var data = JSON.parse(jsonText);
   
    loc["display_name"] = data[0]["display_name"];
    loc["lat"] = data[0]["lat"];
    loc["lon"] = data[0]["lon"];
    return loc;
  
  } catch (e) {
    return loc;
  }
}

